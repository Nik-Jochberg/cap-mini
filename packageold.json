{
  "name": "cap-orders",
  "version": "1.0.0",
  "description": "CAP Orders sample with SQLite",
  "dependencies": {
    "@sap/cds": "^8",
    "@sap/cds-dk": "^8",
    "express": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^1"
  },
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch",
    "deploy": "cds deploy --to sqlite"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": "db/orders.db"
        }
      }
    }
  }
}
